<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="GitOps Platform - Modern Infrastructure Dashboard">
  <meta name="theme-color" content="#2563eb">
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/style.css?v=2">
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect fill='%232563eb' width='32' height='32' rx='6'/%3E%3Cpath d='M8 12h16M8 16h12M8 20h8' stroke='white' stroke-width='2.5' stroke-linecap='round'/%3E%3C/svg%3E">
</head>
<body>
  <!-- Theme Toggle -->
  <button class="theme-toggle" id="themeToggle" aria-label="Toggle theme" title="Toggle dark/light mode">
    <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
    <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
  </button>

  <!-- Header -->
  <header class="header" role="banner">
    <nav class="nav container" aria-label="Main navigation">
      <a href="/" class="nav-brand" aria-label="GitOps Platform Home">
        <svg class="logo" viewBox="0 0 32 32" fill="none" aria-hidden="true">
          <rect width="32" height="32" rx="8" fill="currentColor"/>
          <path d="M8 12h16M8 16h12M8 20h8" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
        </svg>
        <span class="brand-text">GitOps Platform</span>
        <span class="version-badge">v2.0.0</span>
      </a>
      <ul class="nav-links" role="list">
        <li><a href="/" class="nav-link active" data-page="dashboard">Dashboard</a></li>
        <li><a href="/about" class="nav-link" data-page="about">Infrastructure</a></li>
        <li><a href="/metrics" class="nav-link" data-page="metrics">Metrics</a></li>
        <li><a href="/api/system" class="nav-link external" target="_blank" rel="noopener">System API</a></li>
        <li><a href="/api/services" class="nav-link external" target="_blank" rel="noopener">Services API</a></li>
      </ul>
    </nav>
  </header>

  <!-- Progress Bar for Page Loads -->
  <div class="progress-bar" id="progressBar" role="progressbar" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100"></div>

  <main id="mainContent">
    <!-- Hero / Dashboard Header -->
    <section class="hero" aria-labelledby="hero-title">
      <div class="container">
        <div class="hero-grid">
          <div class="hero-content">
            <div class="hero-badges">
              <span class="badge badge-primary">Production Ready</span>
              <span class="badge badge-success">All Systems Operational</span>
              <span class="badge badge-info" id="uptimeBadge">Loading...</span>
            </div>
            <h1 id="hero-title" class="hero-title">
              <span class="hero-title-main">GitOps Platform</span>
              <span class="hero-title-sub">Infrastructure Dashboard</span>
            </h1>
            <p class="hero-description">
              Complete observability and control for your Proxmox-based infrastructure. 
              Monitor services, track deployments, and visualize system health in real-time.
            </p>
            <div class="hero-stats" id="heroStats">
              <div class="stat-card" data-stat="services">
                <span class="stat-value" id="statServices">--</span>
                <span class="stat-label">Services</span>
              </div>
              <div class="stat-card" data-stat="healthy">
                <span class="stat-value" id="statHealthy">--</span>
                <span class="stat-label">Healthy</span>
              </div>
              <div class="stat-card" data-stat="uptime">
                <span class="stat-value" id="statUptime">--</span>
                <span class="stat-label">Uptime</span>
              </div>
              <div class="stat-card" data-stat="deployments">
                <span class="stat-value" id="statDeployments">24</span>
                <span class="stat-label">Deployments</span>
              </div>
            </div>
            <div class="hero-actions">
              <a href="/about" class="btn btn-primary">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
                Explore Infrastructure
              </a>
              <a href="/metrics" class="btn btn-secondary">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="10"/><line x1="6" y1="20" x2="6" y2="10"/><path d="M2 10h20"/></svg>
                View Prometheus Metrics
              </a>
            </div>
          </div>

          <!-- Live System Info Panel -->
          <div class="hero-panel">
            <div class="panel-header">
              <h2 class="panel-title">System Overview</h2>
              <div class="panel-status">
                <span class="status-dot status-online" id="systemStatus"></span>
                <span id="systemStatusText">Checking...</span>
              </div>
            </div>
            <div class="panel-grid" id="systemInfo">
              <div class="info-item">
                <span class="info-label">Hostname</span>
                <span class="info-value" id="sysHostname">--</span>
              </div>
              <div class="info-item">
                <span class="info-label">Platform</span>
                <span class="info-value" id="sysPlatform">--</span>
              </div>
              <div class="info-item">
                <span class="info-label">Architecture</span>
                <span class="info-value" id="sysArch">--</span>
              </div>
              <div class="info-item">
                <span class="info-label">Uptime</span>
                <span class="info-value" id="sysUptime">--</span>
              </div>
              <div class="info-item">
                <span class="info-label">CPU Cores</span>
                <span class="info-value" id="sysCpus">--</span>
              </div>
              <div class="info-item">
                <span class="info-label">Load Avg</span>
                <span class="info-value" id="sysLoad">--</span>
              </div>
              <div class="info-item">
                <span class="info-label">Memory</span>
                <span class="info-value" id="sysMemory">--</span>
              </div>
              <div class="info-item">
                <span class="info-label">Node.js</span>
                <span class="info-value" id="sysNode">--</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Architecture Visualization -->
        <div class="architecture-section">
          <h2 class="section-title">Infrastructure Topology</h2>
          <div class="topology" id="topology">
            <div class="topology-layer">
              <div class="topology-node node-source" data-node="gitlab">
                <div class="node-icon"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M22.65 14.39L12 22.13 1.35 14.39a.84.84 0 0 1-.3-.94l1.22-3.78 2.44-7.51A.42.42 0 0 1 4.82 2a.43.43 0 0 1 .58 0 .42.42 0 0 1 .11.18l2.44 7.49h8.1a.42.42 0 0 1 .11-.18.43.43 0 0 1 .58 0 .42.42 0 0 1 .11.18l2.44 7.49 1.22 3.78a.84.84 0 0 1-.3.94z"/></svg></div>
                <span class="node-label">GitLab CI/CD</span>
                <span class="node-status online">Active</span>
              </div>
              <div class="topology-connector"></div>
              <div class="topology-node node-process" data-node="terraform">
                <div class="node-icon"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg></div>
                <span class="node-label">Terraform</span>
                <span class="node-status online">Applied</span>
              </div>
              <div class="topology-connector"></div>
              <div class="topology-node node-target" data-node="proxmox">
                <div class="node-icon"><svg viewBox="0 0 24 24" fill="currentColor"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg></div>
                <span class="node-label">Proxmox VE</span>
                <span class="node-status online">Healthy</span>
              </div>
            </div>
            <div class="topology-layer vm-layer">
              <div class="vm-grid">
                <div class="topology-node node-vm" data-vm="app">
                  <div class="node-icon"><svg viewBox="0 0 24 24" fill="currentColor"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg></div>
                  <div class="vm-info">
                    <span class="vm-name">gitops-app</span>
                    <span class="vm-ip">192.168.8.189</span>
                    <div class="vm-ports"><span class="port">:3000</span><span class="port">:9100</span></div>
                  </div>
                  <span class="node-status online">Running</span>
                </div>
                <div class="topology-node node-vm" data-vm="db">
                  <div class="node-icon"><svg viewBox="0 0 24 24" fill="currentColor"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg></div>
                  <div class="vm-info">
                    <span class="vm-name">gitops-db</span>
                    <span class="vm-ip">192.168.8.188</span>
                    <div class="vm-ports"><span class="port">:5432</span><span class="port">:9100</span></div>
                  </div>
                  <span class="node-status online">Running</span>
                </div>
                <div class="topology-node node-vm" data-vm="monitoring">
                  <div class="node-icon"><svg viewBox="0 0 24 24" fill="currentColor"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="10"/><line x1="6" y1="20" x2="6" y2="10"/><path d="M2 10h20"/><path d="M6 10a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2h-8a2 2 0 0 1-2-2z"/></svg></div>
                  <div class="vm-info">
                    <span class="vm-name">gitops-monitoring</span>
                    <span class="vm-ip">192.168.8.190</span>
                    <div class="vm-ports"><span class="port">:9090</span><span class="port">:3000</span><span class="port">:9100</span></div>
                  </div>
                  <span class="node-status online">Running</span>
                </div>
                <div class="topology-node node-vm" data-vm="runner">
                  <div class="node-icon"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></div>
                  <div class="vm-info">
                    <span class="vm-name">gitops-runner</span>
                    <span class="vm-ip">192.168.8.170</span>
                    <div class="vm-ports"><span class="port">Docker</span></div>
                  </div>
                  <span class="node-status online">Running</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Services Grid -->
    <section class="services-section" aria-labelledby="services-title">
      <div class="container">
        <header class="section-header">
          <h2 id="services-title" class="section-title">Service Health Monitor</h2>
          <div class="section-actions">
            <button class="btn btn-ghost btn-sm" id="refreshServices">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M23 4v6h-6"/><path d="M1 20v-6h6"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
              Refresh
            </button>
            <span class="last-updated" id="lastUpdated">Last updated: --</span>
          </header>
          <div class="services-grid" id="servicesGrid" role="list">
            <!-- Services loaded dynamically -->
          </div>
        </div>
      </div>
    </section>

    <!-- Metrics Overview -->
    <section class="metrics-section" aria-labelledby="metrics-title">
      <div class="container">
        <header class="section-header">
          <h2 id="metrics-title" class="section-title">Key Metrics</h2>
          <a href="/metrics" class="btn btn-ghost btn-sm">View All Metrics</a>
        </header>
        <div class="metrics-grid" id="metricsGrid">
          <article class="metric-card" data-metric="requests">
            <div class="metric-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg></div>
            <div class="metric-content">
              <span class="metric-label">HTTP Requests</span>
              <span class="metric-value" id="metricRequests">--</span>
            </div>
          </article>
          <article class="metric-card" data-metric="memory">
            <div class="metric-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M6 8h12"/></svg></div>
            <div class="metric-content">
              <span class="metric-label">Memory Usage</span>
              <span class="metric-value" id="metricMemory">--</span>
            </div>
          </article>
          <article class="metric-card" data-metric="cpu">
            <div class="metric-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="4" y="4" width="16" height="16" rx="2"/><path d="M9 9h6v6H9z"/></svg></div>
            <div class="metric-content">
              <span class="metric-label">CPU Usage</span>
              <span class="metric-value" id="metricCpu">--</span>
            </div>
          </article>
          <article class="metric-card" data-metric="uptime">
            <div class="metric-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div>
            <div class="metric-content">
              <span class="metric-label">App Uptime</span>
              <span class="metric-value" id="metricUptime">--</span>
            </div>
          </article>
        </div>
      </div>
    </section>

    <!-- Quick Links -->
    <section class="quick-links" aria-labelledby="links-title">
      <div class="container">
        <h2 id="links-title" class="section-title">Quick Access</h2>
        <div class="links-grid">
          <a href="http://192.168.8.190:3000" target="_blank" rel="noopener" class="link-card">
            <div class="link-icon grafana"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="10"/><line x1="6" y1="20" x2="6" y2="10"/><path d="M2 10h20"/></svg></div>
            <div class="link-info">
              <span class="link-name">Grafana Dashboards</span>
              <span class="link-desc">Visualize metrics & create alerts</span>
            </div>
            <span class="link-url">192.168.8.190:3000</span>
          </a>
          <a href="http://192.168.8.190:9090" target="_blank" rel="noopener" class="link-card">
            <div class="link-icon prometheus"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div>
            <div class="link-info">
              <span class="link-name">Prometheus</span>
              <span class="link-desc">Query metrics & set alerts</span>
            </div>
            <span class="link-url">192.168.8.190:9090</span>
          </a>
          <a href="https://gitlab.com" target="_blank" rel="noopener" class="link-card">
            <div class="link-icon gitlab"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M22.65 14.39L12 22.13 1.35 14.39a.84.84 0 0 1-.3-.94l1.22-3.78 2.44-7.51A.42.42 0 0 1 4.82 2a.43.43 0 0 1 .58 0 .42.42 0 0 1 .11.18l2.44 7.49h8.1a.42.42 0 0 1 .11-.18.43.43 0 0 1 .58 0 .42.42 0 0 1 .11.18l2.44 7.49 1.22 3.78a.84.84 0 0 1-.3.94z"/></svg></div>
            <div class="link-info">
              <span class="link-name">GitLab CI/CD</span>
              <span class="link-desc">Pipeline management & deployments</span>
            </div>
            <span class="link-url">gitlab.com</span>
          </a>
          <a href="/api/system" target="_blank" rel="noopener" class="link-card">
            <div class="link-icon api"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="18" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg></div>
            <div class="link-info">
              <span class="link-name">System API</span>
              <span class="link-desc">REST endpoints for automation</span>
            </div>
            <span class="link-url">/api/system</span>
          </a>
        </div>
      </div>
    </section>
  </main>

  <!-- Footer -->
  <footer class="footer" role="contentinfo">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-brand">
          <a href="/" class="nav-brand" aria-label="GitOps Platform Home">
            <svg class="logo" viewBox="0 0 32 32" fill="none" aria-hidden="true">
              <rect width="32" height="32" rx="8" fill="currentColor"/>
              <path d="M8 12h16M8 16h12M8 20h8" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
            </svg>
            <span class="brand-text">GitOps Platform</span>
          </a>
          <p class="footer-tagline">Modern infrastructure management via GitOps on Proxmox VE</p>
        </div>
        <nav class="footer-nav" aria-label="Footer navigation">
          <div class="footer-col">
            <h4>Platform</h4>
            <ul>
              <li><a href="/">Dashboard</a></li>
              <li><a href="/about">Infrastructure</a></li>
              <li><a href="/metrics">Metrics</a></li>
              <li><a href="/api/system">System API</a></li>
            </ul>
          </div>
          <div class="footer-col">
            <h4>Monitoring</h4>
            <ul>
              <li><a href="http://192.168.8.190:3000" target="_blank">Grafana</a></li>
              <li><a href="http://192.168.8.190:9090" target="_blank">Prometheus</a></li>
              <li><a href="/metrics">App Metrics</a></li>
              <li><a href="/api/services">Services API</a></li>
            </ul>
          </div>
          <div class="footer-col">
            <h4>CI/CD</h4>
            <ul>
              <li><a href="https://gitlab.com" target="_blank">GitLab</a></li>
              <li><a href="https://gitlab.com" target="_blank">Pipelines</a></li>
              <li><a href="https://gitlab.com" target="_blank">Deployments</a></li>
            </ul>
          </div>
        </nav>
      </div>
      <div class="footer-bottom">
        <p class="copyright">GitOps Platform v2.0.0 — Deployed with <span class="heart">♥</span> via GitOps on Proxmox VE</p>
        <div class="footer-links">
          <a href="https://gitlab.com" target="_blank" rel="noopener">GitLab</a>
          <a href="https://www.terraform.io" target="_blank" rel="noopener">Terraform</a>
          <a href="https://prometheus.io" target="_blank" rel="noopener">Prometheus</a>
          <a href="https://grafana.com" target="_blank" rel="noopener">Grafana</a>
        </div>
      </div>
    </div>
  </footer>

  <!-- Toast Container -->
  <div class="toast-container" id="toastContainer" aria-live="polite" aria-atomic="true"></div>

  <script src="/app.js?v=2"></script>
</body>
</html>