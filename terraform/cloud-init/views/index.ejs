<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="GitOps App - Modern infrastructure deployed via GitOps on Proxmox VE">
  <title><%= title %> - GitOps App</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <header class="header">
    <nav class="nav container">
      <a href="/" class="nav-brand" aria-label="GitOps App Home">
        <svg class="logo" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2L2 7l10 5 10-5-10-5z"/>
          <path d="M2 17l10 5 10-5"/>
          <path d="M2 12l10 5 10-5"/>
        </svg>
        <span class="brand-text">GitOps App</span>
      </a>
      <ul class="nav-links">
        <li><a href="/" class="nav-link active">Home</a></li>
        <li><a href="/about" class="nav-link">About</a></li>
        <li><a href="/metrics" class="nav-link">Metrics</a></li>
        <li><a href="https://gitlab.com" target="_blank" rel="noopener noreferrer" class="nav-link external">GitLab</a></li>
      </ul>
    </nav>
  </header>

  <main>
    <section class="hero">
      <div class="container">
        <div class="hero-content">
          <h1 class="hero-title">
            <span class="hero-title-main">Infrastructure as Code</span>
            <span class="hero-title-sub">Deployed via GitOps</span>
          </h1>
          <p class="hero-description">
            A complete production-ready platform running on Proxmox VE with Terraform, GitLab CI/CD, 
            Prometheus monitoring, and Grafana dashboards. All changes tracked in Git.
          </p>
          <div class="hero-actions">
            <a href="/about" class="btn btn-secondary">Learn More</a>
            <a href="/metrics" class="btn btn-primary">View Metrics</a>
          </div>
        </div>

        <div class="hero-visual">
          <div class="architecture-diagram">
            <div class="arch-flow">
              <div class="arch-node arch-gitlab">
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M22.65 14.39L12 22.13 1.35 14.39a.84.84 0 0 1-.3-.94l1.22-3.78 2.44-7.51A.42.42 0 0 1 4.82 2a.43.43 0 0 1 .58 0 .42.42 0 0 1 .11.18l2.44 7.49h8.1a.42.42 0 0 1 .11-.18.43.43 0 0 1 .58 0 .42.42 0 0 1 .11.18l2.44 7.51 1.22 3.78a.84.84 0 0 1-.3.94z"/>
                </svg>
                <span>GitLab</span>
              </div>
              <span class="arch-arrow">→</span>
              <div class="arch-node arch-terraform">
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2V8z"/>
                  <polyline points="14 2 14 8 20 8"/>
                  <line x1="16" y1="13" x2="8" y2="13"/>
                  <line x1="16" y1="17" x2="8" y2="17"/>
                  <polyline points="10 9 9 9 8 9"/>
                </svg>
                <span>Terraform</span>
              </div>
              <span class="arch-arrow">→</span>
              <div class="arch-node arch-proxmox">
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
                  <line x1="8" y1="21" x2="16" y2="21"/>
                  <line x1="12" y1="17" x2="12" y2="21"/>
                </svg>
                <span>Proxmox VE</span>
              </div>
            </div>
            <div class="arch-branches">
              <div class="arch-node arch-vm">
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
                  <line x1="8" y1="21" x2="16" y2="21"/>
                  <line x1="12" y1="17" x2="12" y2="21"/>
                </svg>
                <span>App VM</span>
              </div>
              <div class="arch-node arch-vm">
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <cylinder cx="12" cy="10" r="5" height="10"></cylinder>
                  <rect x="7" y="5" width="10" height="10" rx="1"/>
                </svg>
                <span>DB VM</span>
              </div>
              <div class="arch-node arch-vm">
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <line x1="18" y1="20" x2="18" y2="10"/>
                  <line x1="12" y1="20" x2="12" y2="10"/>
                  <line x1="6" y1="20" x2="6" y2="10"/>
                  <path d="M2 10h20"/>
                  <path d="M6 10a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2h-8a2 2 0 0 1-2-2z"/>
                </svg>
                <span>Monitoring VM</span>
              </div>
              <div class="arch-node arch-vm">
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                </svg>
                <span>Runner VM</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="features">
      <div class="container">
        <h2 class="section-title">Platform Components</h2>
        <div class="features-grid">
          <article class="feature-card">
            <div class="feature-icon">
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 2L2 7l10 5 10-5-10-5z"/>
                <path d="M2 17l10 5 10-5"/>
                <path d="M2 12l10 5 10-5"/>
              </svg>
            </div>
            <h3>Infrastructure as Code</h3>
            <p>All infrastructure defined in Terraform. Version-controlled, reproducible, and auditable.</p>
          </article>
          <article class="feature-card">
            <div class="feature-icon">
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
                <polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
                <line x1="12" y1="22.08" x2="12" y2="12"/>
              </svg>
            </div>
            <h3>GitLab CI/CD</h3>
            <p>Automated pipelines for building, testing, and deploying applications on every commit.</p>
          </article>
          <article class="feature-card">
            <div class="feature-icon">
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <line x1="18" y1="20" x2="18" y2="10"/>
                <line x1="12" y1="20" x2="12" y2="10"/>
                <line x1="6" y1="20" x2="6" y2="10"/>
                <path d="M2 10h20"/>
                <path d="M6 10a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2h-8a2 2 0 0 1-2-2z"/>
              </svg>
            </div>
            <h3>Proxmox Virtualization</h3>
            <p>Four isolated VMs for App, Database, Monitoring, and CI/CD Runner.</p>
          </article>
          <article class="feature-card">
            <div class="feature-icon">
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <line x1="18" y1="20" x2="18" y2="10"/>
                <line x1="12" y1="20" x2="12" y2="10"/>
                <line x1="6" y1="20" x2="6" y2="10"/>
                <path d="M2 10h20"/>
                <path d="M6 10a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2h-8a2 2 0 0 1-2-2z"/>
              </svg>
            </div>
            <h3>Full Observability</h3>
            <p>Prometheus metrics, Grafana dashboards, and Node Exporter on every VM.</p>
          </article>
        </div>
      </div>
    </section>

    <section class="status-bar">
      <div class="container">
        <h2 class="section-title">Service Status</h2>
        <div class="status-grid">
          <div class="status-item">
            <div class="status-indicator status-up"></div>
            <div class="status-info">
              <span class="status-name">App Service</span>
              <span class="status-url">192.168.8.189:3000</span>
            </div>
          </div>
          <div class="status-item">
            <div class="status-indicator status-up"></div>
            <div class="status-info">
              <span class="status-name">PostgreSQL</span>
              <span class="status-url">192.168.8.188:5432</span>
            </div>
          </div>
          <div class="status-item">
            <div class="status-indicator status-up"></div>
            <div class="status-info">
              <span class="status-name">Prometheus</span>
              <span class="status-url">192.168.8.190:9090</span>
            </div>
          </div>
          <div class="status-item">
            <div class="status-indicator status-up"></div>
            <div class="status-info">
              <span class="status-name">Grafana</span>
              <span class="status-url">192.168.8.190:3000</span>
            </div>
          </div>
          <div class="status-item">
            <div class="status-indicator status-up"></div>
            <div class="status-info">
              <span class="status-name">Node Exporter (App)</span>
              <span class="status-url">192.168.8.189:9100</span>
            </div>
          </div>
          <div class="status-item">
            <div class="status-indicator status-up"></div>
            <div class="status-info">
              <span class="status-name">Node Exporter (DB)</span>
              <span class="status-url">192.168.8.188:9100</span>
            </div>
          </div>
          <div class="status-item">
            <div class="status-indicator status-up"></div>
            <div class="status-info">
              <span class="status-name">GitLab Runner</span>
              <span class="status-url">192.168.8.170</span>
            </div>
          </div>
          <div class="status-item">
            <div class="status-indicator status-up"></div>
            <div class="status-info">
              <span class="status-name">Node Exporter (Mon)</span>
              <span class="status-url">192.168.8.190:9100</span>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <footer class="footer">
    <div class="container">
      <p>GitOps App - Deployed with <span class="heart">♥</span> via GitOps on Proxmox VE</p>
      <p class="footer-links">
        <a href="https://gitlab.com" target="_blank" rel="noopener noreferrer">GitLab</a> •
        <a href="https://www.terraform.io" target="_blank" rel="noopener noreferrer">Terraform</a> •
        <a href="https://prometheus.io" target="_blank" rel="noopener noreferrer">Prometheus</a> •
        <a href="https://grafana.com" target="_blank" rel="noopener noreferrer">Grafana</a>
      </p>
    </div>
  </footer>
</body>
</html>